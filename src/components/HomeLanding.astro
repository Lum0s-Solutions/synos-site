  <!-- THREE IMAGES TEASER -->
  <section class="band">
    <div class="hbwrap">
      <div class="sechead reveal">
        <h2>Three images<span class="u">.</span> One codebase.</h2>
        <p>// same kernel, same 245-crate workspace — split by a build-time Curtain</p>
      </div>
      <div class="imgs">
        <a class="icard grim reveal" href="/guides/download/">
          <div class="k">Public · Free</div>
          <h3>GRIMOIRE</h3>
          <p>Learn to hack for real — a shared-world hacking MMO. 117 progressive labs, faction wars, cert-path mapping. Play in the browser or boot the image.</p>
          <span class="go">Get GRIMOIRE →</span>
        </a>
        <a class="icard reveal" href="/guides/download/">
          <div class="k">Sovereign · Free personal</div>
          <h3>GoodLife</h3>
