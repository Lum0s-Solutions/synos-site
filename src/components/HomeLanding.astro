      A({ targets: body, keyframes: [
        { filter: 'hue-rotate(16deg) brightness(1.28) saturate(1.25)', duration: 130, easing: 'easeOutQuad' },
        { filter: 'hue-rotate(0deg) brightness(1) saturate(1)', duration: 300 },
        { filter: 'hue-rotate(8deg) brightness(1.12) saturate(1.1)', duration: 100 },
        { filter: 'hue-rotate(0deg) brightness(1) saturate(1)', duration: 470 } ], loop: true, delay: 1700 });
    });

