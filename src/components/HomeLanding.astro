        for (var i = 0; i < n; i++) {
          var e = ns('circle');
          var x = A.random(120, 742), y = A.random(200, 360);
          e.setAttribute('cx', x); e.setAttribute('cy', y); e.setAttribute('r', A.random(10, 22) / 10);
          e.setAttribute('opacity', 0); embG.appendChild(e);
          A({ targets: e, translateY: -A.random(90, 190), translateX: A.random(-30, 30),
              opacity: [{ value: A.random(6, 9) / 10, duration: 160 }, { value: 0, duration: A.random(700, 1100) }],
              r: [e.getAttribute('r'), 0.2],
              duration: A.random(900, 1400), easing: 'easeOutQuad',
              complete: function (a) { a.animatables[0].target.remove(); } });
        }
      }
