    });

    // (6) HEARTBEAT PULSE — spring/elastic, 1s cardiac cycle locked to shader per=60/bpm
    guard(function () {
      A({ targets: svg, keyframes: [
        { scale: 1.055, duration: 120, easing: 'easeOutQuad' },
        { scale: 1.00, duration: 170, easing: 'easeInQuad' },
        { scale: 1.028, duration: 100, easing: 'easeOutQuad' },
        { scale: 1.00, duration: 610, easing: 'easeOutElastic(1, 0.55)' } ], loop: true, delay: 1700 });
    });

    // outline glow flare on each beat
    guard(function () {
      A({ targets: outline, keyframes: [
        { strokeOpacity: 1, strokeWidth: 22, duration: 120, easing: 'easeOutQuad' },
        { strokeOpacity: 0.5, strokeWidth: 14, duration: 200 },
        { strokeOpacity: 0.78, strokeWidth: 17, duration: 100 },
        { strokeOpacity: 0.45, strokeWidth: 14, duration: 580 } ], loop: true, delay: 1700 });
    });

    // energy pulse courses UP through the silhouette — the phoenix's real veins light up
    guard(function () {
