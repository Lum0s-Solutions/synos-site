              opacity: [{ value: 0, duration: 0 }, { value: 0.95, duration: 160 }, { value: 0.95, duration: 500 }, { value: 0, duration: 340 }],
              r: [2.2, 3.4], duration: 1000, loop: true, easing: 'easeInOutSine',
              delay: 1700 + ci * 120 + i * 333 });
        }
      });
    });

    // (2) RISING EMBERS — sparks spawn from the wings on each beat and drift up + fade
    guard(function () {
      function spawnEmbers() {
