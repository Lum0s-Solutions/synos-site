    });

    // (4) WORDMARK — underscore synaptic flicker on each beat
    guard(function () {
      if (!us) return;
      A({ targets: us, keyframes: [
        { opacity: 1, scale: 1.28, duration: 90, easing: 'easeOutQuad' },
        { opacity: 0.55, scale: 1, duration: 160 },
        { opacity: 1, scale: 1.12, duration: 80 },
        { opacity: 0.85, scale: 1, duration: 670 } ], loop: true, delay: 1900 });
    });

    // (8) DUAL-RHYTHM AMBIENT GLOW — slow breathe under the fast heartbeat
    guard(function () {
      A({ targets: logo, filter: ['drop-shadow(0 0 26px rgba(150,15,15,.55))', 'drop-shadow(0 0 58px rgba(200,35,35,.72))'],
          direction: 'alternate', loop: true, duration: 2600, easing: 'easeInOutSine', delay: 1700 });
    });

