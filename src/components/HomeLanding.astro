      function loop() { cxp += (tx - cxp) * 0.08; cyp += (ty - cyp) * 0.08; logo.style.transform = 'perspective(760px) translate3d(' + cxp + 'px,' + cyp + 'px,0) rotateX(' + (-cyp * 0.55) + 'deg) rotateY(' + (cxp * 0.55) + 'deg)'; raf = requestAnimationFrame(loop); }
      window.addEventListener('pointermove', function (ev) {
        var r = logo.getBoundingClientRect(); tx = ((ev.clientX - (r.left + r.width / 2)) / r.width) * 16; ty = ((ev.clientY - (r.top + r.height / 2)) / r.height) * 12;
      }, { passive: true });
      window.addEventListener('pointerleave', function () { tx = 0; ty = 0; });
      loop();
    });
  }
  (document.readyState === 'loading') ? document.addEventListener('DOMContentLoaded', start) : start();
})();
</script>
